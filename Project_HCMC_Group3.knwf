/* ── Design tokens ───────────────────────────────────────── */
:root {
  --navy: #0d1b2e;
  --panel: #131f30;
  --card: #182335;
  --border: rgba(255, 255, 255, 0.07);
  --accent: #a0c8f7;
  --light: #93c5fd;
  --muted: #64748b;
  --text: #e2e8f0;
  --sub: #94a3b8;
}

/* ── Light Theme ─────────────────────────────────────────── */
body.light-theme {
  --navy: #f8fafc;
  --panel: #f1f5f9;
  --card: #e2e8f0;
  --border: rgba(15, 23, 42, 0.1);
  --accent: #5B8BC1;
  --light: #0369a1;
  --muted: #64748b;
  --text: #0f172a;
  --sub: #475569;
}

/* ── Base Reset ──────────────────────────────────────────── */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html,
body {
  width: 100%;
  height: 100%;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--navy);
  color: var(--text);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* ── App Layout ──────────────────────────────────────────── */
#app {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

main {
  flex: 1;
}

/* ── Navbar ──────────────────────────────────────────────── */
nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 28px;
  border-bottom: 1px solid var(--border);
  background: rgba(13, 27, 46, 0.95);
  backdrop-filter: blur(8px);
  position: sticky;
  top: 0;
  z-index: 200;
}

body.light-theme nav {
  background: rgba(248, 250, 252, 0.95);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
}

.nav-logo-box {
  width: 30px;
  height: 30px;
  background: var(--accent);
  border-radius: 7px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-logo-text h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 14px;
  margin: 0;
}

.nav-logo-text p {
  font-size: 10px;
  color: var(--muted);
  margin: 0;
}

.nav-links {
  display: flex;
  gap: 20px;
}

.nav-links a {
  font-size: 11px;
  color: var(--muted);
  cursor: pointer;
  font-weight: 400;
  transition: all 0.2s ease;
  border: none;
  background: none;
  padding: 0;
  text-decoration: none;
}

.nav-links a:hover {
  color: var(--text);
}

.nav-links a.active {
  color: var(--accent);
  font-weight: 600;
}

.theme-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: rgba(59, 130, 246, 0.1);
  color: var(--light);
  font-size: 16px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: inherit;
}

.theme-toggle:hover {
  background: rgba(59, 130, 246, 0.2);
  border-color: var(--accent);
  transform: scale(1.05);
}

.theme-icon {
  display: inline-block;
  transition: transform 0.3s ease;
}

/* ── Hero Section ────────────────────────────────────────── */
.hero {
  padding: 60px 32px;
  border-bottom: 1px solid var(--border);
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.06) 0%, transparent 60%);
}

.hero-container {
  max-width: 900px;
  margin: 0 auto;
}

.hero-badge {
  font-size: 10px;
  letter-spacing: 0.1em;
  color: var(--light);
  text-transform: uppercase;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 7px;
}

.pulse {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--accent);
  animation: blink 2s infinite;
  display: inline-block;
}

.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: 48px;
  line-height: 1.1;
  margin-bottom: 20px;
  margin-top: 0;
}

.hero h1 em {
  font-style: italic;
  color: var(--light);
}

.hero p {
  font-size: 14px;
  color: var(--sub);
  line-height: 1.7;
  margin: 0;
}

/* ── Section ─────────────────────────────────────────────── */
.section {
  padding: 40px 32px;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
}

.section-container {
  max-width: 900px;
  margin: 0 auto;
}

.section h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 26px;
  margin-bottom: 20px;
  color: var(--text);
  margin-top: 0;
}

.section h3 {
  font-size: 12px;
  font-weight: 600;
  margin-bottom: 8px;
  color: var(--text);
  margin-top: 0;
}

.section-text {
  font-size: 13px;
  line-height: 1.8;
  color: var(--sub);
  margin-bottom: 16px;
  margin-top: 0;
}

.section-text ul {
  margin-left: 20px;
  color: var(--sub);
}

.section-text ul li {
  margin-bottom: 8px;
}

/* ── Category Section ────────────────────────────────────── */
.category-section {
  padding: 32px;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
}

.category-container {
  max-width: 1200px;
  margin: 0 auto;
}

.category-section h1 {
  font-family: 'DM Serif Display', serif;
  font-size: 28px;
  margin-bottom: 24px;
  color: var(--text);
  margin-top: 0;
}

.category-buttons {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.category-btn {
  flex: 1;
  min-width: 250px;
  padding: 18px 24px;
  border-radius: 10px;
  border: 1px solid rgba(59, 130, 246, 0.2);
  background: rgba(59, 130, 246, 0.06);
  color: var(--sub);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: inherit;
}

.category-btn:hover {
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(59, 130, 246, 0.3);
}

.category-btn.active {
  border: 2px solid var(--accent);
  background: rgba(59, 130, 246, 0.15);
  color: var(--accent);
  font-weight: 600;
}

.category-btn span {
  font-size: 18px;
  margin-right: 10px;
}

/* ── Controls Section ────────────────────────────────────── */
.controls-section {
  padding: 32px;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
}

.controls-container {
  max-width: 1200px;
  margin: 0 auto;
}

.controls-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 24px;
  margin-bottom: 20px;
}

.control-group {
  display: flex;
  flex-direction: column;
}

.control-group label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--light);
  margin-bottom: 8px;
  letter-spacing: 0.05em;
}

.control-group input[type="range"],
.control-group select {
  padding: 8px 12px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--card);
  color: var(--text);
  font-size: 12px;
  font-family: inherit;
  cursor: pointer;
}

.control-group input[type="range"] {
  accent-color: var(--accent);
}

.control-group select {
  appearance: none;
  padding-right: 30px;
  background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2393c5fd' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  background-repeat: no-repeat;
  background-position: right 8px center;
  background-size: 20px;
  padding-right: 32px;
}

.chip-group {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 12px;
}

.chip {
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid var(--border);
  color: var(--muted);
  cursor: pointer;
  transition: all 0.15s;
  background: transparent;
  font-family: inherit;
}

.chip.active {
  background: rgba(59, 130, 246, 0.15);
  border-color: var(--accent);
  color: var(--light);
}

.chip:hover {
  border-color: var(--accent);
}

/* ── Dashboard Layout ────────────────────────────────────── */
.dashboard-layout {
  padding: 32px;
  background: var(--navy);
}

.dashboard-container {
  max-width: 1400px;
  margin: 0 auto;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
}

@media (max-width: 1000px) {
  .dashboard-grid {
    grid-template-columns: 1fr;
  }
}

.chart-container {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 24px;
}

.chart-title {
  font-family: 'DM Serif Display', serif;
  font-size: 16px;
  margin-bottom: 20px;
  color: var(--text);
  margin-top: 0;
}

/* ── SVG Map Styles ──────────────────────────────────────– */
.state-path {
  transition: fill 0.55s ease, opacity 0.25s, stroke-width 0.15s;
  cursor: pointer;
  stroke: var(--navy);
  stroke-width: 0.8;
}

.state-path:hover {
  stroke: var(--light);
  stroke-width: 1.5;
  opacity: 0.85;
  filter: brightness(1.1);
}

.state-path.selected {
  stroke: var(--light);
  stroke-width: 2;
}

.state-path.dimmed {
  opacity: 0.2;
}

svg text {
  user-select: none;
  pointer-events: none;
}

/* ── Tooltips ────────────────────────────────────────────── */
.map-tooltip {
  position: fixed;
  background: rgba(13, 27, 46, 0.97);
  border: 1px solid var(--border);
  border-radius: 9px;
  padding: 9px 13px;
  font-size: 11px;
  pointer-events: none;
  z-index: 1000;
  min-width: 130px;
  transition: opacity 0.12s;
  max-width: 200px;
}

/* ── Footer ──────────────────────────────────────────────── */
footer {
  background: var(--panel);
  border-top: 1px solid var(--border);
  padding: 32px;
  text-align: center;
  font-size: 11px;
  color: var(--sub);
}

footer a {
  color: var(--light);
  text-decoration: none;
  transition: color 0.2s;
}

footer a:hover {
  color: var(--accent);
}

/* ── Animations ──────────────────────────────────────────– */
@keyframes blink {

  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.3;
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-in;
}

/* ── Scrollbar ───────────────────────────────────────────── */
::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-track {
  background: var(--panel);
}

::-webkit-scrollbar-thumb {
  background: #1d4ed8;
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--accent);
}

/* ── D3 Chart Styles ─────────────────────────────────────── */
.tick {
  font-size: 11px;
  color: var(--sub);
}

.tick line {
  stroke: var(--border);
  stroke-width: 0.5;
}

.axis {
  color: var(--sub);
}

.axis-label {
  font-size: 12px;
  font-weight: 600;
  fill: var(--light);
}

.bar {
  fill: var(--accent);
  transition: fill 0.2s ease;
}

.bar:hover {
  fill: var(--light);
  filter: brightness(1.1);
}

.pie-slice {
  stroke: var(--navy);
  stroke-width: 2;
  transition: filter 0.2s ease;
}

.pie-slice:hover {
  filter: brightness(1.1);
}

/* ── About Page ──────────────────────────────────────────– */
.about-content {
  max-width: 900px;
  margin: 0 auto;
}

.about-section {
  margin-bottom: 32px;
}

.about-section h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 20px;
  margin-bottom: 16px;
  color: var(--text);
  margin-top: 0;
}

.about-section p {
  font-size: 13px;
  line-height: 1.8;
  color: var(--sub);
  margin: 0 0 12px 0;
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  margin-top: 20px;
}

.team-member {
  padding: 16px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--card);
  text-align: center;
}

.team-member h3 {
  font-size: 13px;
  margin-bottom: 4px;
  color: var(--light);
}

.team-member p {
  font-size: 11px;
  color: var(--sub);
  margin: 0;
}

/* ── Responsive Design ───────────────────────────────────── */
@media (max-width: 768px) {
  nav {
    padding: 12px 16px;
  }

  .nav-links {
    gap: 12px;
  }

  .hero {
    padding: 40px 16px;
  }

  .hero h1 {
    font-size: 32px;
  }

  .section,
  .category-section,
  .controls-section,
  .dashboard-layout {
    padding: 24px 16px;
  }

  .dashboard-grid {
    gap: 16px;
  }

  .category-buttons {
    flex-direction: column;
  }

  .category-btn {
    min-width: auto;
  }

  footer {
    padding: 24px 16px;
  }
}